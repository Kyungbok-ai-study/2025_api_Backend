# 우분투 22.04.1 LTS 환경 설정
# 이 파일을 .env로 복사하여 사용하세요: cp env.ubuntu.example .env

# 기본 설정
PROJECT_NAME=CampusON API
VERSION=1.0.0
DESCRIPTION=경복대학교 학습 지원 플랫폼 API
ENVIRONMENT=production

# 서버 설정
HOST=0.0.0.0
PORT=8000
DEBUG=false

# 보안 설정 (프로덕션에서는 반드시 변경하세요!)
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 데이터베이스 설정
DATABASE_URL=postgresql://admin:1234@localhost:5432/kb_learning_db
DATABASE_ECHO=false

# Qdrant 벡터 데이터베이스 설정
QDRANT_ENABLED=true
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
VECTOR_DIMENSION=768

# Redis 설정 (캐싱)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# CORS 설정
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","https://your-domain.com"]
ALLOWED_METHODS=["GET","POST","PUT","DELETE","OPTIONS"]
ALLOWED_HEADERS=["*"]

# AI 모델 설정
AI_MODEL_NAME=exaone-deep-32b
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7

# OpenAI 설정 (RAG 시스템용)
OPENAI_API_KEY=your-openai-api-key

# Gemini AI 설정
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_NAME=gemini-2.0-flash-exp

# 임베딩 모델 설정
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32

# 파일 업로드 설정
MAX_FILE_SIZE_MB=50
UPLOAD_DIRECTORY=uploads
ALLOWED_FILE_EXTENSIONS=[".pdf",".docx",".txt",".md",".xlsx",".xls"]

# 로깅 설정
LOG_LEVEL=INFO
LOG_FILE=logs/campuson.log

# 우분투 시스템 설정
POPPLER_PATH=/usr/bin
TZ=Asia/Seoul

# 진단 테스트 설정
DIAGNOSIS_TEST_TIME_LIMIT_MINUTES=60
DIAGNOSIS_QUESTIONS_PER_DIFFICULTY=6

# 학습 추천 설정
RECOMMENDATION_ALGORITHM=hybrid
MAX_RECOMMENDATIONS=50

# 보안 헤더 설정
SECURITY_HEADERS_ENABLED=true

# 공개 API 설정
PUBLIC_API_ENABLED=true
PUBLIC_API_RATE_LIMIT=100

# 모니터링 설정
PROMETHEUS_ENABLED=false
GRAFANA_ENABLED=false

# 소셜 로그인 설정 (선택사항)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMS 인증 설정 (선택사항)
SMS_API_KEY=
SMS_API_SECRET=

# 이메일 설정 (선택사항)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD= 